   "cell_type": "markdown",
   "id": "cell-md-05",
   "metadata": {},
   "source": [
    "## ⚙️ Cell 4 — Core Engine: Agent Caller + Debate Orchestrator"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "cell-04",
   "metadata": {},
   "outputs": [],
   "source": [
    "# ─── Topic relevance filter ───────────────────────────────────────\n",
    "KEYWORDS = [\n",
    "    \"solar\",\"photovoltaic\",\"pv\",\"panel\",\"inverter\",\"mppt\",\"irradiance\",\n",
    "    \"sun\",\"sunlight\",\"watt\",\"kilowatt\",\"kwh\",\"efficiency\",\"monocrystalline\",\n",
    "    \"polycrystalline\",\"thin film\",\"bifacial\",\"off-grid\",\"grid-tied\",\n",
    "    \"net metering\",\"wind\",\"turbine\",\"windmill\",\"rotor\",\"blade\",\"wind farm\",\n",
    "    \"offshore\",\"onshore\",\"weibull\",\"capacity factor\",\"betz\",\"anemometer\",\n",
    "    \"renewable\",\"clean energy\",\"green energy\",\"lcoe\",\"payback\",\"battery\",\n",
    "    \"storage\",\"charge controller\",\"peak sun\",\"tilt angle\",\"azimuth\",\n",
    "    \"degradation\",\"temperature coefficient\",\"energy production\",\"power output\",\n",
    "    \"system size\",\"installation\",\"kw\",\"mw\",\"gw\",\"electricity\",\"generation\",\n",
    "    \"levelized\",\"performance ratio\",\"annual output\",\"swept area\"\n",
    "]\n",
    "\n",
    "def is_on_topic(question: str) -> bool:\n",
    "    q = question.lower()\n",
    "    return any(kw in q for kw in KEYWORDS)\n",
    "\n",
    "\n",
    "# ─── Single agent call ────────────────────────────────────────────\n",
    "def call_agent(agent_id: str, messages: list, temperature: float = 0.2) -> str:\n",
    "    \"\"\"\n",
    "    Call the Groq LLM for a specific agent.\n",
    "    Low temperature (0.2) ensures calculation accuracy.\n",
    "    \"\"\"\n",
    "    full_messages = [\n",
    "        {\"role\": \"system\", \"content\": AGENT_PROMPTS[agent_id]}\n",
    "    ] + messages\n",
    "\n",
    "    try:\n",
    "        resp = client.chat.completions.create(\n",
    "            model=MODEL,\n",
    "            messages=full_messages,\n",
    "            max_tokens=1500,\n",
    "            temperature=temperature,\n",
    "        )\n",
    "        return resp.choices[0].message.content.strip()\n",
    "    except Exception as e:\n",
    "        return f\"⚠️ Agent error [{agent_id}]: {e}\"\n",
    "\n",
    "\n",
    "# ─── Multi-agent debate orchestrator ─────────────────────────────\n",
    "def run_debate(question: str, rounds: int = DEBATE_ROUNDS, verbose: bool = True) -> dict:\n",
    "    \"\"\"\n",
    "    Orchestrates the full multi-agent debate:\n",
    "      Round 1..N : Solar Expert + Wind Expert answer independently\n",
    "                   → Skeptic critiques both\n",
    "      Final       : Synthesis agent produces the definitive answer\n",
    "\n",
    "    Returns a dict with debate_rounds list and final_answer string.\n",
    "    \"\"\"\n",
    "\n",
    "    # ── Off-topic guard ──────────────────────────────────────────\n",
    "    if not is_on_topic(question):\n",
    "        return {\n",
    "            \"question\": question,\n",
    "            \"on_topic\": False,\n",
    "            \"debate_rounds\": [],\n",
    "            \"final_answer\": (\n",
    "                \"❌ **Out of scope.**\\n\\n\"\n",
    "                \"I specialize exclusively in **solar panels** and **wind energy**.\\n\\n\"\n",
    "                \"You can ask me about:\\n\"\n",
    "                \"- ☀️ Solar panel sizing, efficiency & calculations\\n\"\n",
    "                \"- 🌬️ Wind turbine power output & capacity factors\\n\"\n",
    "                \"- 💰 System costs, ROI, LCOE & payback periods\\n\"\n",
    "                \"- 🔋 Battery storage, off-grid & grid-tied systems\\n\"\n",
    "                \"- 🌡️ Temperature effects, degradation & real-world losses\"\n",
    "            )\n",
    "        }\n",
    "\n",
    "    debate_log = []\n",
    "    base_msg   = {\n",
    "        \"role\": \"user\",\n",
    "        \"content\": (\n",
    "            f\"Question: {question}\\n\\n\"\n",
    "            \"Provide a thorough expert answer. Show every calculation step-by-step with units.\"\n",
    "        )\n",
    "    }\n",
    "\n",
    "    # ── Debate rounds ────────────────────────────────────────────\n",
    "    for r in range(1, rounds + 1):\n",
    "        if verbose:\n",
    "            print(f\"\\n{'━'*60}\")\n",
    "            print(f\"  🔄 DEBATE ROUND {r} / {rounds}\")\n",
    "            print(f\"{'━'*60}\")\n",
    "\n",
    "        # ── Round 1: fresh answers from both experts ──────────────\n",
    "        if r == 1:\n",
    "            if verbose: print(\"  🔆 Dr. Solar   → thinking...\")\n",
    "            solar = call_agent(\"solar_expert\", [base_msg])\n",
    "\n",
    "            if verbose: print(\"  💨 Dr. Windward → thinking...\")\n",
    "            wind  = call_agent(\"wind_expert\",  [base_msg])\n",
    "\n",
    "        # ── Round 2+: experts refine after critique ───────────────\n",
    "        else:\n",
    "            prev = debate_log[-1]\n",
    "\n",
    "            if verbose: print(\"  🔆 Dr. Solar   → refining...\")\n",
    "            solar = call_agent(\"solar_expert\", [\n",
    "                base_msg,\n",
    "                {\"role\": \"assistant\", \"content\": prev[\"solar\"]},\n",
    "                {\"role\": \"user\",\n",
    "                 \"content\": (\n",
    "                     f\"The critic raised the following issues with your answer:\\n\"\n",
    "                     f\"{prev['critic']}\\n\\n\"\n",
    "                     \"Please revise your answer to address every issue. \"\n",
    "                     \"Re-show all corrected calculations.\"\n",
    "                 )}\n",
    "            ])\n",
    "\n",
    "            if verbose: print(\"  💨 Dr. Windward → refining...\")\n",
    "            wind  = call_agent(\"wind_expert\", [\n",
    "                base_msg,\n",
    "                {\"role\": \"assistant\", \"content\": prev[\"wind\"]},\n",
    "                {\"role\": \"user\",\n",
    "                 \"content\": (\n",
    "                     f\"The critic raised the following issues:\\n\"\n",
    "                     f\"{prev['critic']}\\n\\n\"\n",
    "                     \"Please revise your answer to address every issue. \"\n",
    "                     \"Re-show all corrected calculations.\"\n",
    "                 )}\n",
    "            ])\n",
    "\n",
    "        # ── Skeptic critiques both answers ────────────────────────\n",
    "        if verbose: print(\"  🔍 Dr. Critic  → reviewing...\")\n",
    "        critic = call_agent(\"skeptic_agent\", [\n",
    "            base_msg,\n",
    "            {\"role\": \"assistant\",\n",
    "             \"content\": (\n",
    "                 f\"[Solar Expert]:\\n{solar}\\n\\n\"\n",
    "                 f\"[Wind Expert]:\\n{wind}\"\n",
    "             )},\n",
    "            {\"role\": \"user\",\n",
    "             \"content\": (\n",
    "                 \"Critically review both answers above. \"\n",
    "                 \"Identify every error, missing factor, or unrealistic assumption. \"\n",
    "                 \"Re-verify every number. Be thorough.\"\n",
    "             )}\n",
    "        ])\n",
    "\n",
    "        debate_log.append({\"round\": r, \"solar\": solar, \"wind\": wind, \"critic\": critic})\n",
    "\n",
    "        if verbose:\n",
    "            print(f\"  ✅ Round {r} complete.\")\n",
    "\n",
    "    # ── Final synthesis ──────────────────────────────────────────\n",
    "    if verbose:\n",
    "        print(f\"\\n{'━'*60}\")\n",
    "        print(\"  🎯 Dr. Synthesis → producing final answer...\")\n",
    "        print(f\"{'━'*60}\")\n",
    "\n",
    "    transcript = \"\\n\\n\".join([\n",
    "        (\n",
    "            f\"=== ROUND {d['round']} ===\\n\"\n",
    "            f\"[Solar Expert]:\\n{d['solar']}\\n\\n\"\n",
    "            f\"[Wind Expert]:\\n{d['wind']}\\n\\n\"\n",
    "            f\"[Critic]:\\n{d['critic']}\"\n",
    "        )\n",
    "        for d in debate_log\n",
    "    ])\n",
    "\n",
    "    final = call_agent(\"synthesis_agent\", [\n",
    "        {\"role\": \"user\",\n",
    "         \"content\": (\n",
    "             f\"Original question: {question}\\n\\n\"\n",
    "             f\"Debate transcript:\\n{transcript}\\n\\n\"\n",
    "             \"Produce the final, comprehensive, fully-verified answer now.\"\n",
    "         )}\n",
    "    ], temperature=0.1)   # even lower temp for the final answer\n",
    "\n",
    "    if verbose:\n",
    "        print(\"  ✅ Final answer ready!\\n\")\n",
    "\n",
    "    return {\n",
    "        \"question\": question,\n",
    "        \"on_topic\": True,\n",
    "        \"debate_rounds\": debate_log,\n",
    "        \"final_answer\": final\n",
    "    }\n",
    "\n",
    "\n",
    "print(\"✅ Debate engine loaded.\")"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "cell-md-06",
   "metadata": {},
   "source": [
    "## 🖥️ Cell 5 — Display Helper"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "cell-05",
   "metadata": {},
   "outputs": [],
   "source": [
    "def show(result: dict, show_debate: bool = False):\n",
    "    \"\"\"Pretty-render a debate result in the notebook.\"\"\"\n",
    "\n",
    "    # Header\n",
    "    topic_badge = (\n",
    "        \"<span style='background:#1a5c1a;color:#90ee90;padding:3px 10px;\"\n",
    "        \"border-radius:12px;font-size:12px;'>✅ On-topic</span>\"\n",
    "        if result[\"on_topic\"] else\n",
    "        \"<span style='background:#5c1a1a;color:#ff9090;padding:3px 10px;\"\n",
    "        \"border-radius:12px;font-size:12px;'>❌ Off-topic</span>\"\n",
    "    )\n",
    "\n",
    "    display(HTML(f\"\"\"\n",
    "    <div style='background:#12121f;border:1px solid #333;padding:16px 20px;\n",
    "                border-radius:12px;margin:12px 0;'>\n",
    "      <p style='color:#aaa;font-size:12px;margin:0 0 6px;'>QUESTION</p>\n",
    "      <p style='color:#f0f0f0;font-size:16px;margin:0 0 10px;'>\n",
    "          {result['question']}\n",
    "      </p>\n",
    "      {topic_badge}\n",
    "    </div>\n",
    "    \"\"\"))\n",
    "\n",
    "    # Optional: debate rounds\n",
    "    if show_debate and result.get(\"debate_rounds\"):\n",
    "        for d in result[\"debate_rounds\"]:\n",
    "            display(HTML(\n",
    "                f\"<h3 style='color:#4fc3f7;border-bottom:1px solid #333;\"\n",
    "                f\"padding-bottom:4px;'>🔄 Round {d['round']}</h3>\"\n",
    "            ))\n",
    "            display(HTML(\"<p style='color:#ffd700;font-weight:bold;'>🔆 Dr. Solar</p>\"))\n",
    "            display(Markdown(d[\"solar\"]))\n",
    "            display(HTML(\"<p style='color:#80deea;font-weight:bold;'>💨 Dr. Windward</p>\"))\n",
    "            display(Markdown(d[\"wind\"]))\n",
    "            display(HTML(\"<p style='color:#ef9a9a;font-weight:bold;'>🔍 Dr. Critic</p>\"))\n",
    "            display(Markdown(d[\"critic\"]))\n",
    "            display(HTML(\"<hr style='border-color:#333;'/>\"))\n",
    "\n",
    "    # Final answer\n",
    "    display(HTML(\"\"\"\n",
    "    <div style='background:#0d2137;border-left:4px solid #ffd700;\n",
    "                padding:14px 18px;border-radius:6px;margin:16px 0 4px;'>\n",
    "      <p style='color:#ffd700;font-size:16px;font-weight:bold;margin:0;'>\n",
    "          🎯 Final Answer — Dr. Synthesis\n",
    "      </p>\n",
    "    </div>\n",
    "    \"\"\"))\n",
    "    display(Markdown(result[\"final_answer\"]))\n",
    "\n",
    "\n",
    "def ask(question: str, show_debate: bool = False, rounds: int = DEBATE_ROUNDS):\n",
    "    \"\"\"One-liner chat interface.\"\"\"\n",
    "    print(f\"🚀 Multi-agent debate starting ({rounds} round(s))...\")\n",
    "    t0 = time.time()\n",
    "    result = run_debate(question, rounds=rounds, verbose=True)\n",
    "    print(f\"⏱️  Done in {time.time()-t0:.1f}s\")\n",
    "    show(result, show_debate=show_debate)\n",
    "    return result\n",
    "\n",
    "\n",
    "print(\"✅ Display helpers ready.\")"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "cell-md-07",
   "metadata": {},
   "source": [
    "## 🧮 Cell 6 — Built-in Calculation Utilities (No API needed)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "cell-06",
   "metadata": {},
   "outputs": [],
   "source": [
    "# ════════════════════════════════════════════════════════════════════\n",
    "#  SOLAR SYSTEM CALCULATOR\n",
    "# ════════════════════════════════════════════════════════════════════\n",
    "def solar_system_calc(\n",
    "    daily_kwh: float,\n",
    "    peak_sun_hours: float,\n",
    "    panel_watt: int   = 400,\n",
    "    perf_ratio: float = 0.80,\n",
    "    cost_per_watt: float = 1.0\n",
    ") -> None:\n",
    "    \"\"\"\n",
    "    Print a complete solar system design sheet.\n",
    "\n",
    "    Args:\n",
    "        daily_kwh       : Household daily consumption (kWh)\n",
    "        peak_sun_hours  : Avg peak sun hours/day for location\n",
    "        panel_watt      : Individual panel wattage (W)\n",
    "        perf_ratio      : System performance ratio (0–1)\n",
    "        cost_per_watt   : Installed cost per watt (USD or local currency)\n",
    "    \"\"\"\n",
    "    print(\"\\n\" + \"═\"*58)\n",
    "    print(\"  ☀️  SOLAR SYSTEM CALCULATOR\")\n",
    "    print(\"═\"*58)\n",
    "\n",
    "    # ── System size ──────────────────────────────────────────────\n",
    "    system_kw  = daily_kwh / (peak_sun_hours * perf_ratio)\n",
    "    system_w   = system_kw * 1000\n",
    "    n_panels   = math.ceil(system_w / panel_watt)\n",
    "    actual_w   = n_panels * panel_watt\n",
    "    actual_kw  = actual_w / 1000\n",
    "\n",
    "    # ── Energy production ────────────────────────────────────────\n",
    "    daily_out  = actual_kw * peak_sun_hours * perf_ratio\n",
    "    annual_out = daily_out * 365\n",
    "\n",
    "    # ── Area (≈1.7 m² per 300W, scales linearly) ─────────────────\n",
    "    area_per_panel = 1.7 * (panel_watt / 300)\n",
    "    total_area     = n_panels * area_per_panel\n",
    "\n",
    "    # ── Cost ─────────────────────────────────────────────────────\n",
    "    total_cost = actual_w * cost_per_watt\n",
    "\n",
    "    print(f\"\\n  📥 INPUTS\")\n",
    "    print(f\"     Daily consumption    : {daily_kwh} kWh/day\")\n",
    "    print(f\"     Peak sun hours       : {peak_sun_hours} h/day\")\n",
    "    print(f\"     Panel wattage        : {panel_watt} W\")\n",
    "    print(f\"     Performance ratio    : {perf_ratio*100:.0f}%\")\n",
    "    print(f\"     Cost per watt        : {cost_per_watt}\")\n",
    "\n",
    "    print(f\"\\n  ⚙️  SYSTEM DESIGN\")\n",
    "    print(f\"     Required size        : {system_kw:.2f} kW\")\n",
    "    print(f\"     Panels needed        : {n_panels} × {panel_watt}W\")\n",
    "    print(f\"     Actual system size   : {actual_kw:.2f} kW\")\n",
    "    print(f\"     Total panel area     : {total_area:.1f} m²\")\n",
    "\n",
    "    print(f\"\\n  ⚡ ENERGY PRODUCTION\")\n",
    "    print(f\"     Daily output         : {daily_out:.2f} kWh/day\")\n",
    "    print(f\"     Annual output        : {annual_out:,.0f} kWh/year\")\n",
    "\n",
    "    print(f\"\\n  💰 ECONOMICS\")\n",
    "    print(f\"     Total installed cost : {total_cost:,.0f}\")\n",
    "    print(\"═\"*58)\n",
    "\n",
    "    return dict(\n",
    "        n_panels=n_panels, actual_kw=actual_kw,\n",
    "        annual_kwh=annual_out, total_cost=total_cost\n",
    "    )\n",
    "\n",
    "\n",
    "# ════════════════════════════════════════════════════════════════════\n",
    "#  WIND POWER CALCULATOR\n",
    "# ════════════════════════════════════════════════════════════════════\n",
    "def wind_power_calc(\n",
    "    wind_speed_ms: float,\n",
    "    rotor_diameter_m: float,\n",
    "    cp: float = 0.40,\n",
    "    rho: float = 1.225,\n",
    "    capacity_factor: float = None\n",
    ") -> None:\n",
    "    \"\"\"\n",
    "    Print wind turbine power output.\n",
    "    P = 0.5 × ρ × A × v³ × Cp\n",
    "    \"\"\"\n",
    "    r    = rotor_diameter_m / 2\n",
    "    A    = math.pi * r ** 2\n",
    "    P_w  = 0.5 * rho * A * (wind_speed_ms ** 3) * cp\n",
    "    P_kw = P_w / 1000\n",
    "    P_betz_kw = 0.5 * rho * A * (wind_speed_ms ** 3) * 0.593 / 1000\n",
    "\n",
    "    print(\"\\n\" + \"═\"*58)\n",
    "    print(\"  🌬️  WIND POWER CALCULATOR\")\n",
    "    print(\"═\"*58)\n",
    "    print(f\"\\n  📥 INPUTS\")\n",
    "    print(f\"     Wind speed           : {wind_speed_ms} m/s\")\n",
    "    print(f\"     Rotor diameter       : {rotor_diameter_m} m\")\n",
    "    print(f\"     Power coefficient Cp : {cp}  (Betz max = 0.593)\")\n",
    "    print(f\"     Air density ρ        : {rho} kg/m³\")\n",
    "\n",
    "    print(f\"\\n  🔢 STEP-BY-STEP\")\n",
    "    print(f\"     Radius r = {rotor_diameter_m}/2       = {r} m\")\n",
    "    print(f\"     Area   A = π × {r}²   = {A:.2f} m²\")\n",
    "    print(f\"     P = 0.5 × {rho} × {A:.2f} × {wind_speed_ms}³ × {cp}\")\n",
    "    print(f\"       = 0.5 × {rho} × {A:.2f} × {wind_speed_ms**3:.1f} × {cp}\")\n",
    "    print(f\"       = {P_w:,.1f} W\")\n",
    "\n",
    "    print(f\"\\n  ⚡ OUTPUT\")\n",
    "    print(f\"     Power output         : {P_kw:.2f} kW\")\n",
    "    print(f\"     Betz limit power     : {P_betz_kw:.2f} kW\")\n",
    "    print(f\"     % of Betz limit      : {(cp/0.593)*100:.1f}%\")\n",
    "\n",
    "    if capacity_factor:\n",
    "        aep = capacity_factor * P_kw * 8760\n",
    "        print(f\"\\n  📅 ANNUAL ENERGY (CF = {capacity_factor*100:.0f}%)\")\n",
    "        print(f\"     AEP = {capacity_factor} × {P_kw:.2f} × 8760 = {aep:,.0f} kWh/year\")\n",
    "\n",
    "    print(\"═\"*58)\n",
    "\n",
    "\n",
    "# ════════════════════════════════════════════════════════════════════\n",
    "#  PAYBACK & ROI CALCULATOR\n",
    "# ════════════════════════════════════════════════════════════════════\n",
    "def payback_calc(\n",
    "    system_cost: float,\n",
    "    annual_kwh: float,\n",
    "    electricity_rate: float,\n",
    "    om_annual: float = 0.0,\n",
    "    degradation: float = 0.005,\n",
    "    price_escalation: float = 0.02,\n",
    "    lifetime: int = 25\n",
    ") -> None:\n",
    "    \"\"\"\n",
    "    Print a detailed payback & ROI analysis.\n",
    "\n",
    "    Args:\n",
    "        system_cost      : Total installed cost\n",
    "        annual_kwh       : First-year energy production (kWh)\n",
    "        electricity_rate : Electricity price (per kWh)\n",
    "        om_annual        : Annual O&M cost\n",
    "        degradation      : Annual panel degradation rate (default 0.5%)\n",
    "        price_escalation : Annual electricity price increase (default 2%)\n",
    "        lifetime         : System lifetime in years\n",
    "    \"\"\"\n",
    "    annual_savings_yr1 = annual_kwh * electricity_rate\n",
    "    simple_payback     = system_cost / (annual_savings_yr1 - om_annual)\n",
    "\n",
    "    print(\"\\n\" + \"═\"*68)\n",
    "    print(\"  💰  PAYBACK & ROI ANALYSIS\")\n",
    "    print(\"═\"*68)\n",
    "    print(f\"  System Cost       : {system_cost:,.0f}\")\n",
    "    print(f\"  Year-1 Savings    : {annual_savings_yr1:,.0f}  \"\n",
    "          f\"({annual_kwh:,.0f} kWh × {electricity_rate}/kWh)\")\n",
    "    print(f\"  Annual O&M Cost   : {om_annual:,.0f}\")\n",
    "    print(f\"  Simple Payback    : {simple_payback:.1f} years\")\n",
    "    print(f\"  Degradation/yr    : {degradation*100:.1f}%\")\n",
    "    print(f\"  Price Escalation  : {price_escalation*100:.1f}%/yr\")\n",
    "    print()\n",
    "    print(f\"  {'Year':<6} {'Annual Savings':>16} {'Cumulative':>16} \"\n",
    "          f\"{'Net P&L':>14}  Note\")\n",
    "    print(\"  \" + \"─\"*64)\n",
    "\n",
    "    cumulative    = 0.0\n",
    "    payback_year  = None\n",
    "\n",
    "    for yr in range(1, lifetime + 1):\n",
    "        degraded   = annual_kwh * ((1 - degradation) ** yr)\n",
    "        rate_yr    = electricity_rate * ((1 + price_escalation) ** yr)\n",
    "        savings_yr = degraded * rate_yr - om_annual\n",
    "        cumulative += savings_yr\n",
    "        net        = cumulative - system_cost\n",
    "\n",
    "        if cumulative >= system_cost and payback_year is None:\n",
    "            payback_year = yr\n",
    "\n",
    "        # Print selected years\n",
    "        highlight = yr == payback_year or yr in (1, 5, 10, 15, 20, 25)\n",
    "        if highlight:\n",
    "            flag = \" ◀ PAYBACK\" if yr == payback_year else \"\"\n",
    "            print(f\"  {yr:<6} {savings_yr:>15,.0f}  {cumulative:>15,.0f} \"\n",
    "                  f\"  {net:>12,.0f}{flag}\")\n",
    "\n",
    "    roi_25 = ((cumulative - system_cost) / system_cost) * 100\n",
    "    print(\"  \" + \"─\"*64)\n",
    "    print(f\"\\n  ✅ Realistic Payback : Year {payback_year}\")\n",
    "    print(f\"  ✅ 25-Year Net Profit : {cumulative - system_cost:,.0f}\")\n",
    "    print(f\"  ✅ 25-Year ROI        : {roi_25:.1f}%\")\n",
    "    print(\"═\"*68)\n",
    "\n",
    "\n",
    "# ════════════════════════════════════════════════════════════════════\n",
    "#  TEMPERATURE CORRECTION CALCULATOR\n",
    "# ════════════════════════════════════════════════════════════════════\n",
    "def temp_correction(p_rated_w: float, temp_cell_c: float,\n",
    "                     tc_per_c: float = -0.0035) -> None:\n",
    "    \"\"\"\n",
    "    P_actual = P_rated × [1 + Tc × (T_cell − 25)]\n",
    "\n",
    "    Args:\n",
    "        p_rated_w  : Panel rated power at STC (W)\n",
    "        temp_cell_c: Actual cell temperature (°C)\n",
    "        tc_per_c   : Temperature coefficient per °C  \n",
    "                     (monocrystalline ≈ -0.0035, polycrystalline ≈ -0.004)\n",
    "    \"\"\"\n",
    "    delta_t  = temp_cell_c - 25\n",
    "    p_actual = p_rated_w * (1 + tc_per_c * delta_t)\n",
    "    loss_w   = p_rated_w - p_actual\n",
    "    loss_pct = (loss_w / p_rated_w) * 100\n",
    "\n",
    "    print(\"\\n\" + \"═\"*52)\n",
    "    print(\"  🌡️  TEMPERATURE CORRECTION\")\n",
    "    print(\"═\"*52)\n",
    "    print(f\"  Formula: P_actual = P_rated × [1 + Tc × (T − 25)]\")\n",
    "    print(f\"  P_rated  = {p_rated_w} W\")\n",
    "    print(f\"  T_cell   = {temp_cell_c}°C   (ΔT = {delta_t:+.0f}°C from STC)\")\n",
    "    print(f\"  Tc       = {tc_per_c}/°C\")\n",
    "    print(f\"  ─────────────────────────────────────────────\")\n",
    "    print(f\"  P_actual = {p_rated_w} × [1 + {tc_per_c} × {delta_t}]\")\n",
    "    print(f\"           = {p_rated_w} × {1 + tc_per_c*delta_t:.4f}\")\n",
    "    print(f\"           = {p_actual:.1f} W\")\n",
    "    print(f\"  Power loss = {loss_w:.1f} W  ({loss_pct:.1f}%)\")\n",
    "    print(\"═\"*52)\n",
    "\n",
    "\n",
    "print(\"✅ All calculators loaded.\")\n",
    "print(\"   • solar_system_calc()\")\n",
    "print(\"   • wind_power_calc()\")\n",
    "print(\"   • payback_calc()\")\n",
    "print(\"   • temp_correction()\")"
   ]
  },
